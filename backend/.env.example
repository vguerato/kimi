# ─────────────────────────────────────────────────────────────────────────────
# Kiro AI — Backend v2
# Copie este arquivo para .env e preencha os valores.
# ─────────────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Nível de log: trace | debug | info | warn | error | fatal (padrão: info)
LOG_LEVEL=info

# ── Redis ─────────────────────────────────────────────────────────────────────
# Usado pelo BullMQ para a fila de tarefas.
REDIS_URL=redis://redis:6379

# ── Worker ────────────────────────────────────────────────────────────────────
# Número de tarefas processadas em paralelo pelo worker.
WORKER_CONCURRENCY=3

# ── Provedor LLM ──────────────────────────────────────────────────────────────
# Configure pelo menos UM provedor. O sistema detecta automaticamente qual usar.
# Prioridade: OPENAI > ANTHROPIC > AZURE_OPENAI > GEMINI > OLLAMA

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Anthropic — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-5

# Ollama (local/self-hosted) — https://ollama.com
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2

# Azure OpenAI — https://portal.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_INSTANCE_NAME=my-instance
# AZURE_OPENAI_DEPLOYMENT_NAME=my-deployment
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_MODEL=gpt-4o

# ── Memória do Agente (Mem0) ──────────────────────────────────────────────────
# Fornece memória persistente entre tarefas, por repositório.
#
# Modos (detectados automaticamente):
#   MEM0_API_KEY definido  → Mem0 Cloud  (https://app.mem0.ai → API Keys)
#   MEM0_BASE_URL definido → Mem0 OSS    (servidor self-hosted)
#   Nenhum definido        → Fallback local em /app/data/memory.json
MEM0_API_KEY=
# MEM0_BASE_URL=http://mem0-server:8000

# ── Weaviate (Memória Semântica) ──────────────────────────────────────────────
# Banco de dados vetorial para busca semântica de contexto de projetos.
# Se não configurado, o sistema usa apenas Mem0/fallback local.
# WEAVIATE_URL=http://weaviate:8080
# WEAVIATE_API_KEY=

# ── VCS / Git ─────────────────────────────────────────────────────────────────
# Personal Access Token com escopo 'repo' (GitHub) ou equivalente.
# Configurado via dashboard Settings — não necessário aqui.
# GIT_PAT=
# GITHUB_USERNAME=kiro-agent

# ── Docker (Containers Efêmeros) ─────────────────────────────────────────────
# Socket do Docker para provisionar containers efêmeros.
# Padrão: /var/run/docker.sock (montado via docker-compose)
# DOCKER_HOST=unix:///var/run/docker.sock

# ── Ngrok (opcional) ─────────────────────────────────────────────────────────
# Expõe o endpoint de webhook para a internet em desenvolvimento.
# https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# ── Azure DevOps Boards ───────────────────────────────────────────────────────
# Configurado via dashboard Settings → Integração → Azure DevOps.
# Obtenha um PAT em: https://dev.azure.com/{org}/_usersSettings/tokens
# Escopos necessários: Work Items (Read & Write), Service Hooks (Read & Write)
#
# Chaves armazenadas no banco (settings):
#   azure_devops_org     → nome da organização (ex: "mycompany")
#   azure_devops_project → nome ou ID do projeto (ex: "MyProject")
#   azure_devops_token   → Personal Access Token
